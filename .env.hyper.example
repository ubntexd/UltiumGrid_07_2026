# Instance XRP/USDT (ex-HYPER) — compte Demo Binance SÉPARÉ (ne pas mélanger avec .env BTC ni .env.sol).
# Copier vers .env.hyper et remplir les clés (meme compte que l'ancienne instance HYPER).
#
# Transition 2026-07-06 : HYPERUSDT → XRPUSDT sur la 3e instance (ports 18200/18280 inchangés).

BINANCE_SPOT_REST_BASE=https://demo-api.binance.com
BINANCE_SPOT_WS_BASE=wss://demo-stream.binance.com/ws
BINANCE_SPOT_TESTNET_API_KEY=
BINANCE_SPOT_TESTNET_API_SECRET=

# Identité UI (surchargée aussi par docker-compose.hyper.yml)
ULTIUM_INSTANCE_ID=xrp
ULTIUM_INSTANCE_LABEL=UltiumGrid — Instance XRP
ULTIUM_TRADING_SYMBOL=XRPUSDT
ULTIUM_ACCENT=#0ea5e9
