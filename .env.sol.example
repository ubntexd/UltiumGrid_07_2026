# Instance SOL/USDT — compte Demo Binance SÉPARÉ (ne pas mélanger avec .env BTC).
# Copier vers .env.sol et remplir les clés fournies par l'utilisateur.

BINANCE_SPOT_REST_BASE=https://demo-api.binance.com
BINANCE_SPOT_WS_BASE=wss://demo-stream.binance.com/ws
BINANCE_SPOT_TESTNET_API_KEY=
BINANCE_SPOT_TESTNET_API_SECRET=

# Identité UI (surchargée aussi par docker-compose.sol.yml)
ULTIUM_INSTANCE_ID=sol
ULTIUM_INSTANCE_LABEL=UltiumGrid — Instance SOL
ULTIUM_ACCENT=#a855f7
