# --- Binance Spot Demo Mode (clés depuis https://demo.binance.com) ---
# Docs: https://developers.binance.com/docs/binance-spot-api-docs/demo-mode/general-info
# NE PAS utiliser testnet.binance.vision avec des clés demo.binance.com (-2015).
# NE JAMAIS committer de vraies clés.

BINANCE_SPOT_REST_BASE=https://demo-api.binance.com
BINANCE_SPOT_WS_BASE=wss://demo-stream.binance.com/ws
BINANCE_SPOT_TESTNET_API_KEY=
BINANCE_SPOT_TESTNET_API_SECRET=

# Alias acceptés par le code (mêmes valeurs) :
# BINANCE_FUTURES_TESTNET_API_KEY=
# BINANCE_FUTURES_TESTNET_API_SECRET=

