#   2. API Management → Create API
# Les clés de l'ancien testnet.binancefuture.com NE SONT PAS interchangeables
# (account peut répondre 200 mais POST /order reste en -1007).
# NE JAMAIS mettre de vraies clés dans ce fichier (commité).

BINANCE_FUTURES_REST_BASE=https://demo-fapi.binance.com
BINANCE_FUTURES_WS_BASE=wss://demo-fstream.binance.com
BINANCE_FUTURES_TESTNET_API_KEY=
BINANCE_FUTURES_TESTNET_API_SECRET=

